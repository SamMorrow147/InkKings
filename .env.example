# Copy this file to .env.local for local development
# Set NEXT_PUBLIC_SITE_URL on Vercel under Project Settings → Environment Variables → Production

# URL priority used for og:image / iMessage / Facebook share thumbnails:
#   1. NEXT_PUBLIC_SITE_URL  (set this once your custom domain is live)
#   2. VERCEL_URL            (auto-set by Vercel on every deploy — works in the interim)
#   3. Hardcoded fallback    (local dev only)

# No trailing slash
# Current deploy URL (interim) — swap this for your custom domain when it's live
NEXT_PUBLIC_SITE_URL=https://ink-kings.vercel.app
